use_pip_packages() {
    pip --no-input -qq install -U -r "$1"
}

use_kubeseal_cert() {
  local cache_file
  cache_file="$(direnv_layout_dir)/sealed-secrets.crt"

  if [[ ! -f "$cache_file" ]]; then
    kubeseal --fetch-cert > "$cache_file"
  fi

  export SEALED_SECRETS_CERT="$cache_file"
}

layout python "/opt/homebrew/bin/python3.11"

use pip_packages "$(expand_path requirements.txt)"
use kubeseal_cert
